# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Local development — backend running on localhost:5081
VITE_API_BASE_URL=http://localhost:5081/api/v1

# Railway production — set this in the Railway service Variables tab (not in a file)
# VITE_API_BASE_URL=https://webapimoneymanager-production.up.railway.app/api/v1
